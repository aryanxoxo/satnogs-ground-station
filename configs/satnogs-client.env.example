# Copy these values into SatNOGS Config / Ansible host variables.
# Do not commit real API tokens or private station credentials.

SATNOGS_STATION_ID=0000
SATNOGS_STATION_LAT=49.2827
SATNOGS_STATION_LON=-123.1207
SATNOGS_STATION_ELEV=70

# SDR receiver. For RTL-SDR this is usually enough after udev setup.
SATNOGS_SOAPY_RX_DEVICE=driver=rtlsdr
SATNOGS_RX_SAMPLE_RATE=2.4e6
SATNOGS_PPM_ERROR=0
SATNOGS_RF_GAIN=32.8

# Antenna metadata for station notes and link-budget sanity checks.
STATION_ANTENNA_TYPE=turnstile
STATION_ANTENNA_BAND=VHF/UHF
STATION_LNA_PRESENT=false
STATION_FILTER_PRESENT=false

# Optional rotator settings. Leave disabled for fixed-antenna stations.
SATNOGS_ROT_ENABLED=false
SATNOGS_ROT_MODEL=202
SATNOGS_ROT_PORT=localhost:4533
SATNOGS_ROT_BAUD=9600

# Network/API values should be entered in the SatNOGS configuration UI.
SATNOGS_NETWORK_API_TOKEN=replace-with-local-secret-only

